#define BLYNK_PRINT Serial
#define BLYNK_TEMPLATE_ID "YOUR_TEMPLATE_ID"
#define BLYNK_TEMPLATE_NAME "Weather Monitoring"
#define BLYNK_AUTH_TOKEN "YOUR_AUTH_TOKEN"

#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>
#include <DHT.h>
#include <Wire.h>
#include <LiquidCrystal_I2C.h>

char ssid[] = "YOUR_WIFI_NAME";
char pass[] = "YOUR_WIFI_PASSWORD";

#define DHTPIN D4
#define DHTTYPE DHT11
#define RAIN_PIN A0
#define LDR_PIN D0

DHT dht(DHTPIN, DHTTYPE);
LiquidCrystal_I2C lcd(0x27, 16, 2);
BlynkTimer timer;

void sendSensorData()
{
  float h = dht.readHumidity();
  float t = dht.readTemperature();
  int rainValue = analogRead(RAIN_PIN);
  int ldrValue = digitalRead(LDR_PIN);

  if (isnan(h) || isnan(t)) {
    Serial.println("Failed to read from DHT sensor!");
    return;
  }

  Serial.print("Temp: ");
  Serial.print(t);
  Serial.print(" C, Humidity: ");
  Serial.print(h);
  Serial.print(" %, Rain: ");
  Serial.print(rainValue);
  Serial.print(", LDR: ");
  Serial.println(ldrValue);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("T:");
  lcd.print(t);
  lcd.print("C H:");
  lcd.print(h);

  lcd.setCursor(0, 1);
  lcd.print("R:");
  lcd.print(rainValue);
  lcd.print(" L:");
  lcd.print(ldrValue);

  Blynk.virtualWrite(V0, t);
  Blynk.virtualWrite(V1, h);
  Blynk.virtualWrite(V2, rainValue);
  Blynk.virtualWrite(V3, ldrValue);
}

void checkBlynkStatus()
{
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi disconnected");
  }

  if (!Blynk.connected()) {
    Serial.println("Blynk not connected");
  }
}

void setup()
{
  Serial.begin(115200);

  dht.begin();
  lcd.init();
  lcd.backlight();

  WiFi.begin(ssid, pass);
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(2000L, sendSensorData);     // send every 2 seconds
  timer.setInterval(5000L, checkBlynkStatus);   // check status every 5 seconds
}

void loop()
{
  Blynk.run();
  timer.run();
}
